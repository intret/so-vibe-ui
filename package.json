{
  "name": "so-vibe-ui",
  "version": "0.1.0",
  "description": "Embed a vibe-coding terminal into any frontend project. Alt+V toggles a floating iframe with xterm.js connected to a PTY backend.",
  "type": "module",
  "main": "./dist/sdk/index.js",
  "module": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/sdk/index.d.ts",
        "default": "./dist/sdk/index.js"
      },
      "require": {
        "types": "./dist/sdk/index.d.cts",
        "default": "./dist/sdk/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      }
    },
    "./vite-plugin": {
      "import": {
        "types": "./dist/vite-plugin/index.d.ts",
        "default": "./dist/vite-plugin/index.js"
      }
    }
  },
  "bin": {
    "so-vibe-ui": "./dist/server/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "node build.js",
    "build:sdk": "tsup src/sdk/index.ts --format esm,cjs --dts --clean --minify --target es2020 --out-dir dist/sdk",
    "build:terminal": "node build-terminal.js",
    "build:server": "tsup src/server/index.ts src/server/cli.ts --format esm --dts --clean --target node18 --platform node --out-dir dist/server --external express --external ws --external node-pty --external commander",
    "dev:sdk": "tsup src/sdk/index.ts --format esm,cjs --dts --minify --target es2020 --out-dir dist/sdk --watch",
    "dev:server": "tsup src/server/index.ts src/server/cli.ts --format esm --dts --target node18 --platform node --out-dir dist/server --external express --external ws --external node-pty --external commander --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vibe-coding",
    "terminal",
    "xterm",
    "iframe",
    "devtools",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "esbuild": "^0.25.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.4"
  }
}
